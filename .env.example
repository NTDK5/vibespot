# API base URL (used by src/config/axios.js)
# Production: https://vibespot-backend.onrender.com/api
# Local dev:   http://192.168.x.x:5000/api  (use LAN IP on physical device)
# Leave empty or omit to default to production.
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Public web origin for share links (https://fena.app/s/:id, /p/:id)
EXPO_PUBLIC_APP_URL=https://fena.app

# Google OAuth — see GOOGLE_SIGNIN_SETUP.md for step-by-step instructions.
# Web client ID is required. Platform-specific IDs are recommended for native builds.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# PostHog product analytics (free tier) — https://posthog.com
# US cloud default; use https://eu.i.posthog.com for EU
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set to true to send events from dev builds
EXPO_PUBLIC_POSTHOG_ENABLE_DEV=false
